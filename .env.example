# ── 좋은날 환경 변수 예시 ──────────────────────────────────
# 실제 값은 .env.local 에 넣고 커밋하지 않는다.

# 결제 기능 플래그 (Phase 5). false 면 프리미엄 UI 는 "준비 중" 상태로 노출.
PAYMENT_ENABLED=false

# 카카오 애드핏 광고단위 (결과 페이지 상/하단). 비우면 해당 슬롯 미노출.
# 애드핏 콘솔에서 goodday.fineboll.com 등록 후 320x100 광고단위 2개를 만들어 ID 입력.
NEXT_PUBLIC_ADFIT_UNIT_TOP=
NEXT_PUBLIC_ADFIT_UNIT_BOTTOM=

# (선택) Google AdSense — 애드핏 대신 쓸 경우. 비우면 미로딩.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_ENABLED=false

# Kakao JS SDK (공유). 비우면 카카오 공유 비활성.
NEXT_PUBLIC_KAKAO_JS_KEY=

# Formspree 등 무료 폼 (프리미엄 알림 신청). 폼 엔드포인트 URL.
NEXT_PUBLIC_NOTIFY_FORM_ENDPOINT=

# 서비스 기본 URL (OG 이미지 절대경로 생성용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
